# MOMO Script 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ─────────────────────────────────────────────────────────────────────────────
# 全局共享配置 (Turso 管理配置)
# ─────────────────────────────────────────────────────────────────────────────
# 仅用于“自动创建用户数据库”流程，所有用户共享
TURSO_MGMT_TOKEN=your_turso_management_token_here
TURSO_ORG_SLUG=your_organization_slug_here
TURSO_GROUP=123

# 中央用户 Hub 数据库 (可选，用于用户管理和审计)
TURSO_HUB_DB_URL=libsql://your-hub-database.turso.io
TURSO_HUB_AUTH_TOKEN=your_hub_auth_token_here

# ─────────────────────────────────────────────────────────────────────────────
# 运行配置
# ─────────────────────────────────────────────────────────────────────────────
FORCE_CLOUD_MODE=False # 开源默认：允许本地运行
BATCH_SIZE=1           # AI 批处理大小

# ─────────────────────────────────────────────────────────────────────────────
# 用户配置 (自动生成，无需手动设置)
# ─────────────────────────────────────────────────────────────────────────────
# MOMO_USER=your_username  # 当前活跃用户
#
# 每个用户的敏感凭证请放在: data/profiles/<username>.env
# 建议格式示例：
# MOMO_TOKEN=your_maimemo_access_token_here
# AI_PROVIDER=mimo
# MIMO_API_KEY=your_mimo_api_key_here
# 或：
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# 用户数据库连接（按用户隔离）
# TURSO_DB_URL=https://your-user-db.turso.io
# TURSO_AUTH_TOKEN=your_user_db_token
