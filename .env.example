# MOMO Script 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ─────────────────────────────────────────────────────────────────────────────
# 墨墨背单词 API 配置
# ─────────────────────────────────────────────────────────────────────────────
MOMO_TOKEN=your_maimemo_access_token_here

# ─────────────────────────────────────────────────────────────────────────────
# AI 提供商配置 (二选一)
# ─────────────────────────────────────────────────────────────────────────────

# 选项 1: 小米 Mimo (默认)
AI_PROVIDER=mimo
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_BASE=https://api.xiaomimimo.com/v1

# 选项 2: Google Gemini
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────────────────────────────────────
# 云端数据库配置 (Turso/libSQL)
# ─────────────────────────────────────────────────────────────────────────────
TURSO_DB_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
TURSO_DB_HOSTNAME=your-database.turso.io

# 中央用户 Hub 数据库
TURSO_HUB_DB_URL=libsql://your-hub-database.turso.io
TURSO_HUB_AUTH_TOKEN=your_hub_auth_token_here

# ─────────────────────────────────────────────────────────────────────────────
# 安全配置
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD_HASH=your_admin_password_hash_here
ENCRYPTION_KEY=your_encryption_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 运行配置
# ─────────────────────────────────────────────────────────────────────────────
FORCE_CLOUD_MODE=True  # 强制使用云端数据库
BATCH_SIZE=1           # AI 批处理大小

# ─────────────────────────────────────────────────────────────────────────────
# 用户配置 (自动生成，无需手动设置)
# ─────────────────────────────────────────────────────────────────────────────
# MOMO_USER=your_username  # 当前活跃用户
