# 墨墨背单词 OpenAPI Access Token
# 获取地址: https://open.maimemo.com/
MOMO_TOKEN=your_momo_token_here

# Google Gemini API Key
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (可选) 指定模型，默认为 gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# (可选) 批处理单词数量，推荐 20
BATCH_SIZE=20

# 小米 Mimo API 配置 (可选)
# 获取地址: https://api.mioffice.cn/ (需要申请 API Key)
MIMO_API_KEY=your_mimo_api_key_here
MIMO_MODEL=mimo-v2-flash
MIMO_API_BASE=https://api.mioffice.cn/v1

# AI 提供商选择: "gemini" 或 "mimo"
# 默认使用 Gemini，设置为 "mimo" 时优先使用小米 Mimo
AI_PROVIDER=gemini
