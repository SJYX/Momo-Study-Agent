{
  "name": "momo-web-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen:types": "python ../../scripts/generate_frontend_types.py --output src/api/types.ts",
    "gen:openapi": "python ../../scripts/export_web_openapi.py --output src/api/openapi.json",
    "sync:api": "npm run gen:types && npm run gen:openapi"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.6.3",
    "vite": "^6.0.0"
  }
}
